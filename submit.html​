<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <title>达人提交 - 终极测试页</title>
    <style>
        body { font-family: sans-serif; max-width: 500px; margin: 40px auto; padding: 20px; }
        input, select, button { display: block; width: 100%; padding: 10px; margin: 10px 0; box-sizing: border-box; }
        button { background: #4285f4; color: white; border: none; cursor: pointer; }
        #result { margin-top: 20px; padding: 15px; border-radius: 5px; white-space: pre-wrap; }
        .success { background-color: #d4edda; color: #155724; border: 1px solid #c3e6cb; }
        .error { background-color: #f8d7da; color: #721c24; border: 1px solid #f5c6cb; }
    </style>
</head>
<body>
    <h2>达人信息提交（终极测试）</h2>
    <p>此页面使用最简方法提交，用于验证GAS后台是否工作。</p>
    <form id="submitForm">
        <input type="text" name="category" placeholder="分类（必填）" value="测试类" required>
        <input type="text" name="handle" placeholder="账号（必填）" value="@final_test_user" required>
        <input type="url" name="userLink" placeholder="链接（必填）" value="https://example.com/finaltest" required>
        <select name="syncSheet">
            <option value="提报表">提报表</option>
            <option value="菲律宾（邓）">菲律宾（邓）</option>
            <option value="墨西哥（子豪）">墨西哥（子豪）</option>
        </select>
        <button type="submit">🚀 提交测试</button>
    </form>
    <div id="result"></div>

    <script>
        // 🔧 请将下面的URL替换为您在第一步中获得的全新 [您的新GAS_URL]
        const GAS_URL = 'https://script.google.com/macros/s/AKfycbzs9kGq1fwcxcQwxifjPJyR1N8hhWRJKHzTWQAAhMktXuyU5xbX_hJRhsNRt_Z_6pjeVQ/exec';

        document.getElementById('submitForm').addEventListener('submit', async function(e) {
            e.preventDefault();
            const form = e.target;
            const resultDiv = document.getElementById('result');
            const submitBtn = form.querySelector('button[type="submit"]');
            
            // 收集表单数据
            const formData = new FormData(form);
            const data = Object.fromEntries(formData.entries());
            
            // 禁用按钮，显示等待
            submitBtn.disabled = true;
            submitBtn.textContent = '提交中...';
            resultDiv.textContent = '正在向云端发送请求...';
            resultDiv.className = '';
            
            try {
                console.log('发送数据:', data);
                // 发送POST请求
                const response = await fetch(GAS_URL, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json', // 明确使用JSON格式
                    },
                    body: JSON.stringify(data)
                });
                
                console.log('响应状态:', response.status);
                const result = await response.json();
                console.log('响应内容:', result);
                
                // 显示结果
                resultDiv.textContent = result.message;
                resultDiv.className = result.success ? 'success' : 'error';
                
                if (result.success) {
                    form.reset(); // 清空表单
                }
                
            } catch (error) {
                console.error('请求失败:', error);
                resultDiv.textContent = '❌ 网络请求失败: ' + error.message;
                resultDiv.className = 'error';
            } finally {
                // 恢复按钮
                submitBtn.disabled = false;
                submitBtn.textContent = '🚀 提交测试';
            }
        });
        
        // 页面加载时显示GAS地址
        console.log('测试页已加载，目标GAS: ', GAS_URL);
    </script>
</body>
</html>
